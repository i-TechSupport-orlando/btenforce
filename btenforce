# Function to add missing LOG_RETENTION to the config file if not found.
fix_missing_vars () {
    if grep "^LOG_RETENTION=" "$BTENFORCE_CONFIG" >/dev/null; then
        return 0
    else
        echo "LOG_RETENTION=\"180\"" >> "$BTENFORCE_CONFIG"
        return 0
    fi
}

# Function to run a command as the logged in user.
runAsUser() {
    # Recheck for logged in user before executing osascript in the event the user logs out between the initial check and this function call.
    loggedInUser=$( echo "show State:/Users/ConsoleUser" | scutil | awk '/Name :/ && ! /loginwindow/ { print $3 }' )

    if [[ -z "${loggedInUser}" ]] && [[ "${loggedInUser}" != "loginwindow" ]]; then
	    # Exit if no user is logged in. btenforce is user-facing.
	    append_log "No user logged in. Exiting."
	    exit 0
    fi

    uid=$( id -u "${loggedInUser}" 2>/dev/null ) || true

    # Execute the command sent to the function as the logged in user.
    launchctl asuser "$uid" sudo -u "$loggedInUser" "$@" || true
}

# Function to remove log files older than the retention period.
prune_logs () {
    local retention="${1:-$LOG_RETENTION}"
    local log_file="${2:-$BTENFORCE_LOG_FILE}"

    # Default to 180 days if missing or empty.
    if [[ -z "$retention" ]] || [[ "$retention" == "" ]]; then
        retention="180"
        if ! fix_missing_vars; then
            append_log "Failed to fix missing vars."
            return 1
        fi
    fi

    # Remove log files older than the retention period.
    find "$(dirname "$log_file")" \
        -name "$(basename "$log_file")" \
        -mtime +"${retention}" \
        -delete
    
    if [[ $? -ne 0 ]]; then
        return 1
    fi
}

set_btenforce_interval () {
    if [[ -z "$BTENFORCE_INTERVAL" ]]; then
        BTENFORCE_INTERVAL="5"
    fi

    # Get current interval
    current_interval=$( plutil -extract "StartInterval" raw "$PLIST" 2>/dev/null )
    
    if [[ "$current_interval" == "$BTENFORCE_INTERVAL" ]]; then
        return 0
    fi

    # Replace the interval.
    plutil -replace StartInterval -integer "$BTENFORCE_INTERVAL" "$PLIST"
    
    # Fix permissions.
    chown root:wheel "$PLIST"
    chmod 644 "$PLIST"

    # Validate the plist file.
    plutil -lint "$PLIST"
    if [[ $? -ne 0 ]]; then
        append_log "Error: Could not validate the plist file."
        return 1
    fi

    append_log "Set interval to ${BTENFORCE_INTERVAL}."

    return 0
}

# Download and install the LaunchDaemon if it doesn't exist.
download_daemon () {
    local daemon_url temp_file sha256 sha256_local
    daemon_url="https://raw.githubusercontent.com/i-TechSupport-orlando/btenforce/refs/heads/main/com.itech.btenforce.plist"
    temp_file="/tmp/com.itech.btenforce.plist.new"

    # Get expected sha256 checksum.
    sha256=$( curl -fsSL "$daemon_url" | shasum -a 256 | awk '{ print $1 }' )

    if [[ -z "$sha256" ]] || [[ "${#sha256}" -ne 64 ]]; then
        append_log "Error: Could not get sha256 checksum of daemon. Output: ${sha256}"
        return 1
    fi

    local max_attempts=3
    local attempt=1

    while [[ "$attempt" -le "$max_attempts" ]]; do
        if curl -fsSL "$daemon_url" -o "$temp_file"; then
            sha256_local=$( shasum -a 256 "$temp_file" | awk '{ print $1 }' )

            if [[ "$sha256_local" != "$sha256" ]]; then
                append_log "Error: SHA256 checksum of downloaded daemon does not match expected checksum."
                rm -f "$temp_file"
            else
                if ! mv "$temp_file" "$PLIST"; then
                    append_log "Error: Could not move daemon to ${PLIST}."
                    rm -f "$temp_file"
                    return 1
                fi

                if chown root:wheel "$PLIST"; then
                    append_log "Ownership of daemon changed to root:wheel."
                else
                    append_log "Failed to change ownership of daemon to root:wheel."
                    return 1
                fi

                if chmod 644 "$PLIST"; then
                    append_log "Permissions of daemon set to 644."
                else
                    append_log "Failed to set permissions of daemon to 644."
                    return 1
                fi

                return 0
            fi
        else
            append_log "Error: Could not download daemon from GitHub on attempt ${attempt}. Retrying..."
        fi

        sleep 2
        (( attempt += 1 ))
    done

    append_log "Error: Could not download daemon from GitHub after ${max_attempts} attempts."
    return 1
}

# Function to install the LaunchDaemon.
install_daemon () {
    
    if ! download_daemon; then
        append_log "Failed to download daemon."
        return 1
    fi

    append_log "Starting new LaunchDaemon..."

    launchctl bootstrap system "$PLIST"

    sleep 2

    daemon_status=$( launchctl list | grep "com.itech.btenforce" || true )

    if [[ -n "$daemon_status" ]]; then
        append_log "LaunchDaemon installed and loaded."
        return 0
    else
        append_log "LaunchDaemon failed to start. Reattempting to bootstrap..."
        launchctl bootstrap system "$PLIST"
        sleep 3
        daemon_status=$( launchctl list | grep "com.itech.btenforce" || true )
        if [[ -n "$daemon_status" ]]; then
            append_log "LaunchDaemon installed and loaded."
            return 0
        else
            append_log "LaunchDaemon failed to start."
            return 1
        fi
    fi
}

download_blueutil () {
    
    local blueutil_url="https://github.com/i-TechSupport-orlando/btenforce/raw/refs/heads/main/blueutil"
    local temp_file="/tmp/blueutil.new"
    local sha256
    local sha256_local

    # Get expected sha256 checksum.
    sha256=$( curl -fsSL "$blueutil_url" | shasum -a 256 | awk '{ print $1 }' )

    if [[ -z "$sha256" ]] || [[ "${#sha256}" -ne 64 ]]; then
        append_log "Error: Could not get sha256 checksum of blueutil. Output: ${sha256}"
        return 1
    fi

    local max_attempts=3
    local attempt=1

    while [[ "$attempt" -le "$max_attempts" ]]; do
        if curl -fsSL "$blueutil_url" -o "$temp_file"; then
            sha256_local=$( shasum -a 256 "$temp_file" | awk '{ print $1 }' )

            if [[ "$sha256_local" != "$sha256" ]]; then
                append_log "Error: SHA256 checksum of downloaded blueutil does not match expected checksum."
                rm -f "$temp_file"
            else
                if ! mv "$temp_file" "$BLUEUTIL"; then
                    append_log "Error: Could not move blueutil to ${BLUEUTIL}."
                    rm -f "$temp_file"
                    return 1
                fi

                if ! chown root:wheel "$BLUEUTIL"; then
                    append_log "Failed to change ownership of blueutil to root:wheel."
                    return 1
                fi

                if ! chmod 644 "$BLUEUTIL"; then
                    append_log "Failed to set permissions of blueutil to 644."
                    return 1
                fi

                if ! chmod +x "$BLUEUTIL"; then
                    append_log "Failed to set blueutil to executable."
                    return 1
                fi


                return 0
            fi
        else
            append_log "Error: Could not download blueutil from GitHub on attempt ${attempt}. Retrying..."
        fi

        sleep 2
        (( attempt += 1 ))
    done

    append_log "Error: Could not download blueutil from GitHub after ${max_attempts} attempts."

}

# Check whether Bluetooth is on or off.
check_bluetooth () {

    local blue_util_src="/usr/local/share/blueutil"
    
    # Double check that blueutil is executable.
    if [[ ! -x "$BLUEUTIL" ]]; then
        if [[ -f "$blue_util_src" ]]; then
            cp "$blue_util_src" "$BLUEUTIL"
            if [[ ! -f "$BLUEUTIL" ]]; then
                append_log "Could not find ${BLUEUTIL}."
                if ! download_blueutil; then
                    append_log "Failed to download blueutil. Exiting without action."
                    return 1
                else
                    append_log "Downloaded blueutil from GitHub."
                fi
            fi
        else
            append_log "Error: Could not find Bluetooth utility source file at ${blue_util_src}. Attempting to download blueutil from GitHub."
            if ! download_blueutil; then
                append_log "Failed to download blueutil. Exiting without action."
                return 1
            fi
        fi
        chmod +x "$BLUEUTIL"
        append_log "Copied Bluetooth utility from ${blue_util_src} to ${BLUEUTIL}."
    fi

    loggedInUser=$( echo "show State:/Users/ConsoleUser" | scutil | awk '/Name :/ && ! /loginwindow/ { print $3 }' )
    uid=$( id -u "$loggedInUser" 2>/dev/null ) || true

    # Required to run as root.
    export BLUEUTIL_ALLOW_ROOT=1
    
    bstatus=$( launchctl asuser "$uid" sudo -u "$loggedInUser" "$BLUEUTIL" -p )
    
    # If Bluetooth is off, turn it back on.
    if [[ "$bstatus" -eq 0 ]]; then
        launchctl asuser "$uid" sudo -u "$loggedInUser" "$BLUEUTIL" --power 1 2>/dev/null || true
        append_log "Reactivated Bluetooth. User: ${loggedInUser}"
    fi
}

# Close Safari by killing the process if it's open.
check_safari () {
    
    if [[ "$SAFARI_CONTROL_METHOD" == "osascript" ]]; then
    
        safari_is_open=$( runAsUser osascript -e '
tell application "System Events"
set safariRunning to (name of processes) contains "Safari"
end tell

if safariRunning then
    tell application "Safari"
        if (count of windows) > 0 then
            return "true"
        end if
    end tell
end if

return "false"
' 2>/dev/null )
        if [[ "$safari_is_open" == "true" ]]; then
            killall Safari &> /dev/null
            append_log "Killed Safari for ${loggedInUser} via osascript."
            return 0
        fi
    elif [[ "$SAFARI_CONTROL_METHOD" == "pgrep" ]]; then
            safariProcs=$( ps aux | pgrep Safari )
            
        if pgrep -x "Safari" >/dev/null; then
            killall Safari &> /dev/null
            append_log "Killed Safari for ${loggedInUser} via pgrep"
            return 0
        fi
    else
        append_log "Invalid SAFARI_CONTROL_METHOD in ${BTENFORCE_CONFIG}."
        return 1
    fi
}

# Check whether the current date/time is during regular school hours.
during_school_hours () {
    if [[ "$BTENFORCE_DEBUG_MODE" == "true" || "$TIME_CONSTRAINT_OVERRIDE" == "true" ]]; then
        if [[ -f "$OVERRIDE_FLAG" ]]; then
            return 0
        else
            set_flag "$OVERRIDE_FLAG"
            append_log "School hours are not being considered due to debug mode or time constraint override set to true. Created override flag."
            return 0
        fi
    else
        if [[ -f "$OVERRIDE_FLAG" ]]; then
            rm -f "$OVERRIDE_FLAG"
            append_log "School hours are now being considered. Removed override flag."
        fi
    fi

    # Get current time
    current_hour=$(date +%H)
    current_minute=$(date +%M)
    day_of_week=$(date +%u)
    
    # Convert to integers
    current_total_minutes=$((10#$current_hour * 60 + 10#$current_minute))
    
    # Extract hours and minutes from HH:MM strings and calculate total minutes
    start_hour=${BTENFORCE_START_TIME%:*}
    start_minute=${BTENFORCE_START_TIME#*:}
    start_total_minutes=$((10#$start_hour * 60 + 10#$start_minute))

    end_hour=${BTENFORCE_STOP_TIME%:*}
    end_minute=${BTENFORCE_STOP_TIME#*:}
    end_total_minutes=$((10#$end_hour * 60 + 10#$end_minute))
    
    # Check if weekday (Mon–Fri) and time is between start and end
    if (( day_of_week >= 1 && day_of_week <= 5 )); then
        if (( current_total_minutes >= start_total_minutes && current_total_minutes < end_total_minutes )); then
            return 0
        fi
    fi
    
    return 1
}

# Check if any login items exist for the current user.
check_login_items () {
    login_item_count=$(runAsUser osascript -e '
    tell application "System Events"
    count login items
    end tell
    ' 2>/dev/null)
        
    if [[ "$login_item_count" =~ ^[0-9]+$ ]] && [[ "$login_item_count" -gt 0 ]]; then
        runAsUser osascript -e 'tell application "System Events" to delete login items' 2>/dev/null
        append_log "Removed ${login_item_count} login items for ${loggedInUser}"
    fi
}

finished() {
    if [[ "$EXIT_CODE" -ne 0 ]]; then
        append_log "Exit code ${EXIT_CODE}."
    fi
    
    exit "$EXIT_CODE"
}

trapint() {
    if [[ -t 1 ]]; then
        append_log "Control-C was pressed. Script terminated by ${loggedInUser}."
    else
        append_log "btenforce received a Control-C sequence or SIGKILL from an unknown source."
    fi

	exit "$EXIT_CODE"
}

set_flag () {
    local file="$1"

    if [[ -z "$file" ]]; then
        append_log "No file argument received in set_flag function."
        return 1
    fi

    if ! touch "$file"; then
        append_log "Could not create flag file: ${file}."
        return 1
    fi

    if ! chmod 644 "$file"; then
        append_log "Could not set permissions to 644: ${file}."
        return 1
    fi
    
    if ! chown root:wheel "$file"; then
        append_log "Could not set ownership to root:wheel: ${file}."
        return 1
    fi
    
    return 0
}


            

# ══════════╣ MAIN SCRIPT ╠═══════════

# Exit if running as a regular user. Prevents reconfiguring by standard users.
(( EUID != 0 )) && { append_log "Must be run as root"; exit 112; }

trap "finished" EXIT
trap "trapint" INT TERM
trap '[[ -f "$0" ]] && append_log "Error on line $LINENO: $(sed -n ${LINENO}p \"$0\")" || append_log "Error in $0 on line $LINENO"' ERR

# Process arguments if there are any.
if [[ "$#" -ge 1 ]]; then
    while [[ "$#" -gt 0 ]]; do
        case $1 in
            -configure)
                configure_btenforce
                shift
            ;;
            -debug)
                BTENFORCE_DEBUG_MODE="true"
                append_log "${YELLOW}----- [ Debug Mode ]-----${NC}"
                shift
            ;;
            *)
                append_log "${RED}Unknown option: $1${NC}"
                shift
            ;;
        esac
    done
fi

if ! prune_logs; then
    append_log "Failed to prune logs."
fi

# Source the configuration file.
if [[ -f "$BTENFORCE_CONFIG" ]]; then
    source "$BTENFORCE_CONFIG"
else
    append_log "Unable to find ${BTENFORCE_CONFIG}"
    exit 1
fi

if [[ "$BTENFORCE_DEBUG_MODE" == "true" ]]; then
    set -x
    append_log "Debug mode has been enabled."
    debug_info
else
    set +x
fi

# Check if the daemon is enabled.
if [[ "$BTENFORCE_ACTIVE" == "true" ]]; then

    # Check if inactive flag exists. If so, remove it.
    if [[ -f "$INACTIVE_FLAG" ]]; then
        rm -f "$INACTIVE_FLAG"
        append_log "Inactive flag removed. btenforce is now active."
    fi

    # Check the day and time, then perform actions if the current time is within the specified period.
    if during_school_hours; then
        
        # Install the daemon if missing, then check each item.
        if [[ ! -f "$PLIST" ]]; then
            if ! install_daemon; then
                exit 113
            fi
        fi

        # Remove the night/weekend flag if it exists.
        if [[ -f "$NIGHTWKN_FLAG" ]]; then
            rm -f "$NIGHTWKN_FLAG"
            append_log "Night/weekend flag removed. School hours."
        fi

        if [[ "$ACTIVE_USER" == "true" ]]; then
            if [[ "$BLUETOOTH_CONTROL" == "allow" && $SAFARI_CONTROL == "allow" && $LOGIN_ITEM_CONTROL == "allow" ]]; then

                # Change BTENFORCE_ACTIVE to false in the config file and exit.
                sed -i '' 's|BTENFORCE_ACTIVE=".*"|BTENFORCE_ACTIVE="false"|' "$BTENFORCE_CONFIG"
                append_log "All controls are set to allow. Changing BTENFORCE_ACTIVE to false and exiting."
                exit 0
            fi
            
            if [[ "$BLUETOOTH_CONTROL" == "enforce" ]]; then
                check_bluetooth
            fi
            
            if [[ "$SAFARI_CONTROL" == "enforce" ]]; then
                check_safari
            fi
            
            if [[ "$LOGIN_ITEM_CONTROL" == "enforce" ]]; then
                check_login_items
            fi
        else
            # Check if no login flag exists, then create one if needed.
            if [[ ! -f "$NO_LOGIN_FLAG" ]]; then
                set_flag "$NO_LOGIN_FLAG"
                append_log "Nobody is logged on. Created no login flag.."
                exit "$EXIT_CODE"
            else
                # Exit without logging since the flag already exists. This prevents filling the logs when nobody is logged on.
                exit "$EXIT_CODE"
            fi
        fi
    else
        # Create flag file so it doesn't log every execution when school is not in session.
        if [[ ! -f "$NIGHTWKN_FLAG" ]]; then
            set_flag "$NIGHTWKN_FLAG"
            append_log "Not during school hours. Created night/weekend flag."
        fi
    fi
else
    # Check if inactive flag exists. If not, create it.
    if [[ ! -f "$INACTIVE_FLAG" ]]; then
        set_flag "$INACTIVE_FLAG"
        append_log "BTENFORCE_ACTIVE is not set to true. Creating inactive flag. btenforce is now inactive."
        exit 0
    else
        # Exit without logging since the flag already exists. This prevents filling the logs during downtime.
        exit 0
    fi
fi

exit 0
