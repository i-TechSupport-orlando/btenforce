                append_log "${RED}Invalid value entered: ${BTENFORCE_STOP_TIME} - Defaulting to 15:00.${NC}"
                BTENFORCE_STOP_TIME="15:00"
            fi
        fi
    else
        append_log "${GREEN}Timeout has expired. Defaulting to 15:00.${NC}"
        BTENFORCE_STOP_TIME="15:00"
    fi

    echo "-------------------------------"

    (( option_number += 1 ))
    # Set the retention period for log files. Default is 180 days.
    if read -t 600 "LOG_RETENTION?[${option_number}/${total_options}] Enter log retention period in days from 7-1095 (Press enter for [${ORANGE}180${NC}]): "; then
        if [[ -z "$LOG_RETENTION" ]]; then
            append_log "${GREEN}Using default log retention of 180 days.${NC}"
            LOG_RETENTION="180"
        elif [[ "$LOG_RETENTION" =~ ^(7|8|9|[1-9][0-9]|[1-9][0-9]{2}|10[0-8][0-9]|109[0-5])$ ]]; then
            append_log "${GREEN}Log retention is set to ${LOG_RETENTION} days.${NC}"
        else
            append_log "${RED}Invalid value entered: ${LOG_RETENTION} - Defaulting to 180 days.${NC}"
            LOG_RETENTION="180"
        fi
    else
        append_log "${GREEN}Timeout has expired. Defaulting to 180.${NC}"
        LOG_RETENTION="180"
    fi

    echo "-------------------------------"

    (( option_number += 1 ))
    # Log file path. Use a new variable so that the log currently running isn't affected.
    local new_log_path=""
    if read -t 600 "new_log_path?[${option_number}/${total_options}] Enter log file path (press enter for [${ORANGE}${BTENFORCE_LOG_FILE}${NC}]): "; then
