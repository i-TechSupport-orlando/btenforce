    if [[ -z "$sha256" ]] || [[ "${#sha256}" -ne 64 ]]; then
        append_log "Error: Could not get sha256 checksum of blueutil. Output: ${sha256}"
        return 1
    fi

    local max_attempts=3
    local attempt=1

    while [[ "$attempt" -le "$max_attempts" ]]; do
        if curl -fsSL "$blueutil_url" -o "$temp_file"; then
