# Application configuration and status flag files locations.
CONFIG_DIR="/Library/Application Support/i-Tech"
NIGHTWKN_FLAG="${CONFIG_DIR}/btenforce.nw"
INACTIVE_FLAG="${CONFIG_DIR}/btenforce.ina"
OVERRIDE_FLAG="${CONFIG_DIR}/btenforce.ov"
