            append_log "\n${GREEN}Invalid or no entry. Defaulting to pgrep Safari blocking method.${NC}"
        fi
    else
        append_log "\n${GREEN}Timeout has expired. Defaulting to pgrep Safari blocking method.${NC}"
        SAFARI_CONTROL_METHOD="pgrep"
    fi

