    (( option_number += 1 ))
    # School start time in 24-hour clock. HH:mm
    if read -t 600 "BTENFORCE_START_TIME?[${option_number}/${total_options}] Enter school start time (5 characters as in 07:00 or press ENTER for [${ORANGE}07:00${NC}]): "; then
        if [[ -z "$BTENFORCE_START_TIME" ]]; then
            append_log "${GREEN}Using default school start time of 07:00.${NC}"
