VERSION="2.1"
SCRIPT_PATH="${0:A}"
EXIT_CODE="0"
ACTIVE_USER="false"
OVERWRITE_BLUEUTIL="false"

# Status flags.
NIGHTWKN_FLAG="/Library/Application Support/i-Tech/btenforce.nw"
INACTIVE_FLAG="/Library/Application Support/i-Tech/btenforce.ina"
OVERRIDE_FLAG="/Library/Application Support/i-Tech/btenforce.ov"
NO_LOGIN_FLAG="/Library/Application Support/i-Tech/btenforce.nologin"

# Git repository for update checks.
REPO="https://github.com/i-TechSupport-orlando/btenforce"

# Application configuration file.
BTENFORCE_CONFIG="/Library/Application Support/i-Tech/btenforce.env"
BTENFORCE_LOG_FILE="/var/log/btenforce.log"
BLUEUTIL="/usr/local/bin/blueutil"
TODAY=$( date +%Y-%m-%d )
PLIST="/Library/LaunchDaemons/com.itech.btenforce.plist"

# Terminal color variables.
YELLOW=$'\033[1;33m'
GREEN=$'\033[0;32m'
BLUE=$'\033[1;34m'
RED=$'\033[0;31m'
ORANGE=$'\033[38;2;255;165;0m'
NC=$'\033[0m' # No color

# Add the date and time stamp to the log file.
append_log () {
    local message="$1"
    
    # The sed pipeline removes ANSI escape sequences and deletes the first line if it is empty.
    local clean_text="$( echo -e "$message" | sed 's/\x1b\[[0-9;]*m//g' | sed '1{/^$/d;}' )"
    
    local date_stamp="$( date +"%Y-%m-%d %H:%M:%S" )"
    local file_log_msg="${date_stamp} -- ${clean_text}"
    local syslog_msg="version ${VERSION} -- ${clean_text}"

    # If stdout is a terminal (interactive session), keep the colors.
    if [[ -t 1 ]]; then
        # Echo the message with the ANSI color codes to the terminal.
        echo -e "$message"
    fi

    # Append clean message to the persistent log file
    echo "$file_log_msg" >> "$BTENFORCE_LOG_FILE"
    
    # Log to syslog without echoing to stderr again
    logger -i -t btenforce "$syslog_msg"
}

# Username of the user currently logged on and their ID.
loggedInUser=$( echo "show State:/Users/ConsoleUser" | scutil | awk '/Name :/ && ! /loginwindow/ { print $3 }' )
if [[ -z "$loggedInUser" ]]; then
	# Exit if no user is logged in. btenforce is user-facing.
	append_log "No user logged in."
	EXIT_CODE=1
else
	ACTIVE_USER="true"

    # Remove no login flag if it exists.
    if [[ -f "$NO_LOGIN_FLAG" ]]; then
        rm -f "$NO_LOGIN_FLAG"
        append_log "No login flag removed. ${loggedInUser} logged on."
    fi
fi

# Get the user ID of the logged-in user.
uid=$( id -u "${loggedInUser}" )

# If no user ID is found for the logged in user, log and change exit code.
if [[ -z "$uid" ]]; then
	append_log "No user ID found for user ${loggedInUser}. Exiting."
	EXIT_CODE=1
fi


# Function to display debug information.
debug_info() {
    local files_to_check log_size current_bt_status current_interval
    
    append_log "BTENFORCE_CONFIG:         ${BTENFORCE_CONFIG}"
    append_log "BTENFORCE_LOG_FILE:       ${BTENFORCE_LOG_FILE}"
    append_log "BTENFORCE_ACTIVE:         ${BTENFORCE_ACTIVE}"
    append_log "TODAY:                    ${TODAY}"
    append_log "APP_BUNDLE_DIR:           ${APP_BUNDLE_DIR}"
    append_log "PLIST:                    ${PLIST}"
    append_log "BLUEUTIL_ALLOW_ROOT:      ${BLUEUTIL_ALLOW_ROOT}"
    append_log "SAFARI_CONTROL:           ${SAFARI_CONTROL}"
    append_log "SAFARI_CONTROL_METHOD:    ${SAFARI_CONTROL_METHOD}"
    append_log "loggedInUser:             ${loggedInUser}"
    append_log "User ID:                  ${uid}"
    append_log "TIME_CONSTRAINT_OVERRIDE: ${TIME_CONSTRAINT_OVERRIDE}"

    # Get current interval
    current_interval=$( plutil -extract "StartInterval" raw "$PLIST" 2>/dev/null )
    append_log "Current interval:         ${current_interval} (from plist)"
    append_log "Configured interval:      ${BTENFORCE_INTERVAL} (from config file)"

    files_to_check=("$NIGHTWKN_FLAG" "$INACTIVE_FLAG" "$OVERRIDE_FLAG" "$PLIST" "$BTENFORCE_CONFIG" "$BTENFORCE_LOG_FILE" "$NO_LOGIN_FLAG" "/usr/local/bin/blueutil")
    
    for file in "${files_to_check[@]}"; do
        if [[ -f "$file" ]]; then
            append_log "  ${file} ${GREEN}exists${NC}"
        else
            append_log "  ${file} ${RED}does not exist${NC}"
        fi
    done

    log_size=$( du -sh "$BTENFORCE_LOG_FILE" | awk '{ print $1 }' )
    append_log "Log file size: ${log_size}"

    export BLUEUTIL_ALLOW_ROOT=1

    # Get current Bluetooth status
    if [[ -x "/usr/local/bin/blueutil" ]]; then
        if /usr/local/bin/blueutil -p; then
            current_bt_status="${GREEN}enabled${NC}"
        else
            current_bt_status="${RED}disabled${NC}"
        fi
        append_log "Current Bluetooth status: ${current_bt_status}"
    else
        append_log "blueutil not found at /usr/local/bin/blueutil or it's not executable."
    fi

}

# Function to validate that a time value is formatted correctly. 24-hour clock.
check_time_integer() {
    local time="$1"
    local time_regex='^([0-9]|0[0-9]|1[0-9]|2[0-3]):[0-5][0-9]$'

    if [[ ! "$time" =~ $time_regex ]]; then
        return 1
	fi

	# Split the string on the colon character into an array.
	local time_array=(${(s/:/)time})

	local hour="${time_array[1]}"
	local minute="${time_array[2]}"

	# Using 10# forces base-10 evaluation, avoiding octal errors with 08 or 09.
	if (( 10#$hour >= 0 && 10#$hour <= 23 )) && (( 10#$minute >= 0 && 10#$minute <= 59 )); then
		return 0
	fi
    return 1
}

# Function to add a leading zero to the first digit in the time if missing.
add_leading_zero() {
    local time="$1"
	local time_array=(${(s/:/)time})
	local hour="${time_array[1]}"
	local minute="${time_array[2]}"

	# Strip any existing leading zeros to avoid double padding
	hour="${hour#"${hour%%[!0]*}"}"
	minute="${minute#"${minute%%[!0]*}"}"
	
	# If they were entirely zeros (e.g. "00"), they become empty. Default to 0.
	hour="${hour:-0}"
	minute="${minute:-0}"

	printf "%02d:%02d\n" "$hour" "$minute"
}

# Configuration function. Called with -configure argument.
configure_btenforce() {
    failed_items=0

    clear
    local total_options=11
    local option_number=0

    TERM=xterm-256color

    # Check to ensure that the config file path is valid.
    config_dir=$( dirname "$BTENFORCE_CONFIG" )
    if [[ ! -d "$config_dir" ]]; then
        mkdir -p "$config_dir"
        if [[ $? -ne 0 ]]; then
            append_log "\n${RED}Could not create configuration directory: ${config_dir}. Exiting.${NC}"
            exit 1
        else
            append_log "\n${GREEN}Configuration directory confirmed: ${config_dir}${NC}"
        fi
    fi

    echo -e " ╔═════════════════════════════╗ "
    echo -e " ║   btenforce Config Builder  ║ "
    echo -e " ║ ${ORANGE} _     _____         _      ${NC}║ "
    echo -e " ║ ${ORANGE}(_)   |_   _|__  ___| |___  ${NC}║ "
    echo -e " ║ ${ORANGE}| |_____| |/ _ \/ __| '_  \ ${NC}║ "
    echo -e " ║ ${ORANGE}| |_____| |  __/ (__| | | | ${NC}║ "
    echo -e " ║ ${ORANGE}|_|     |_|\___|\___|_| |_| ${NC}║ "
    echo -e " ║                             ║ "
    echo -e " ║ Author: Keith Myers, i-Tech ║ "
    echo -e " ║ (C) 2026 i-Tech Support Inc ║ "
    echo -e " ╚═════════════════════════════╝ "
    echo ""

    if (( EUID != 0 )); then
        append_log "\n${RED}Error: This script must be run with sudo or as root.${NC}\n" >&2
        exit 1
    fi

    echo -e "\nPlease note that this utility changes the configuration of btenforce on"
    echo -e "${ORANGE}this computer only${NC}. To change the config on multiple computers, use the"
    echo -e "post-install script: btenforce-postinstall.sh using an MDM.\n"

    echo -e "Press ENTER for the default value shown in square brackets or make a selection:\n"

    (( option_number += 1 ))
    # Enable/disable the daemon as a whole.
    if read -s -k 1 -t 600 "BTENFORCE_ACTIVE?[${option_number}/${total_options}] Enable btenforce? ([${ORANGE}Y${NC}]/N): "; then
        if [[ "$BTENFORCE_ACTIVE" == "Y" || "$BTENFORCE_ACTIVE" == "y" ]]; then
            BTENFORCE_ACTIVE="true"
            append_log "\n${GREEN}You indicated yes. btenforce is now enabled.${NC}"
        elif [[ "$BTENFORCE_ACTIVE" == "N" || "$BTENFORCE_ACTIVE" == "n" ]]; then
            BTENFORCE_ACTIVE="false"
            append_log "\n${RED}You indicated no. btenforce is now disabled.${NC}"
        else
            append_log "\n${GREEN}Invalid or no entry. Defaulting to enable. btenforce is now enabled.${NC}"
            BTENFORCE_ACTIVE="true"
        fi
    else
        append_log "\n${GREEN}Timeout has expired. Defaulting to enable. btenforce is now enabled.${NC}"
        BTENFORCE_ACTIVE="true"
    fi

    echo "-------------------------------"

    (( option_number += 1 ))
	# Regex for between 1 and 3600.
	interval_regex='^([1-9]|[1-9][0-9]{1,2}|[1-2][0-9]{3}|3[0-5][0-9]{2}|3600)$'
	if read -t 600 "BTENFORCE_INTERVAL?[${option_number}/${total_options}] Enter the number of seconds between 1 and 3600 to wait between checks [${ORANGE}5${NC}]: "; then
		if [[ -z "$BTENFORCE_INTERVAL" ]]; then
			BTENFORCE_INTERVAL="5"
			echo -e "${GREEN}Using default interval ${BTENFORCE_INTERVAL}.${NC}"
		else
			# Check against regex.
			if [[ "$BTENFORCE_INTERVAL" =~ "$interval_regex" ]]; then
				if [[ "$BTENFORCE_INTERVAL" -ge 600 ]]; then
					echo -e "${YELLOW}The interval is set to ten minutes or longer. btenforce may not be effective. A maximum of 10 seconds is recommended with 5 being optimal.${NC}"
				elif [[ "$BTENFORCE_INTERVAL" -le 4 ]]; then
					echo -e "${YELLOW}An interval of less than 5 seconds may be too short! 5 is optimal.${NC}"
				elif [[ "$BTENFORCE_INTERVAL" -ge 60 ]]; then
					echo -e "${YELLOW}An interval of a full minute or longer may be too long! 5 is optimal."
				fi
				echo -e "${GREEN}Interval set to: ${BTENFORCE_INTERVAL}.${NC}"
			else
				echo -e "${RED}Invalid value entered: ${BTENFORCE_INTERVAL} - Defaulting to 5.${NC}"
			fi
		fi
	else
		echo -e "${YELLOW}Timeout has expired. Defaulting to: 5.${NC}"
        BTENFORCE_INTERVAL="5"
	fi

    # Modify the plist and restart the daemon if the Interval was changed from its default.
    if [[ "$BTENFORCE_INTERVAL" != 5 ]]; then
        append_log "\n${GREEN}Resetting the interval...${NC}"
        set_btenforce_interval
    fi

    echo "-------------------------------"

    (( option_number += 1 ))
    # Safari option. 'enforce' or 'allow'
    if read -s -k 1 -t 600 "SAFARI_CONTROL?[${option_number}/${total_options}] Enforce Safari restrictions? (force students to use Chrome, for example) (Y/[${ORANGE}N${NC}]): "; then
        if [[ "$SAFARI_CONTROL" == "Y" || "$SAFARI_CONTROL" == "y" ]]; then
            SAFARI_CONTROL="enforce"
            append_log "\n${GREEN}You indicated yes. Safari restrictions are now enabled.${NC}"
        elif [[ "$SAFARI_CONTROL" == "N" || "$SAFARI_CONTROL" == "n" ]]; then
            SAFARI_CONTROL="allow"
            append_log "\n${RED}You indicated no. Safari restrictions are now disabled.${NC}"
        else
            append_log "\n${GREEN}Invalid or no entry. Defaulting to allow. Safari restrictions are now disabled.${NC}"
            SAFARI_CONTROL="allow"
        fi
    else
        append_log "\n${GREEN}Timeout has expired. Defaulting to allow. Safari restrictions are now disabled.${NC}"
        SAFARI_CONTROL="allow"
    fi

    echo "-------------------------------"

    (( option_number += 1 ))
    # Bluetooth option. 'enforce' or 'allow'
    if read -s -k 1 -t 600 "BLUETOOTH_CONTROL?[${option_number}/${total_options}] Enforce Bluetooth restrictions? (students will not be able to turn off Bluetooth) ([${ORANGE}Y${NC}/N]): "; then
        if [[ "$BLUETOOTH_CONTROL" == "Y" || "$BLUETOOTH_CONTROL" == "y" ]]; then
            BLUETOOTH_CONTROL="enforce"
            append_log "\n${GREEN}You indicated yes. Bluetooth enforcement is now enabled.${NC}"
        elif [[ "$BLUETOOTH_CONTROL" == "N" || "$BLUETOOTH_CONTROL" == "n" ]]; then
            BLUETOOTH_CONTROL="allow"
            append_log "\n${RED}You indicated no. Bluetooth enforcement is now disabled.${NC}"
        else
            append_log "\n${GREEN}Invalid or no entry. Defaulting to enforce. Bluetooth enforcement is now enabled.${NC}"
            BLUETOOTH_CONTROL="enforce"
        fi
    else
        append_log "\n${GREEN}Timeout has expired. Defaulting to enforce. Bluetooth enforcement is now enabled.${NC}"
        BLUETOOTH_CONTROL="enforce"
    fi

    echo "-------------------------------"

    (( option_number += 1 ))
    # Login item controls. 'enforce' or 'allow'
    if read -s -k 1 -t 600 "LOGIN_ITEM_CONTROL?[${option_number}/${total_options}] Enforce login item controls? (restrict students from adding or removing login items) (Y/[${ORANGE}N${NC}]): "; then
        if [[ "$LOGIN_ITEM_CONTROL" == "Y" || "$LOGIN_ITEM_CONTROL" == "y" ]]; then
            LOGIN_ITEM_CONTROL="enforce"
            append_log "\n${GREEN}You indicated yes. Students will not be able to save login items.${NC}"
        elif [[ "$LOGIN_ITEM_CONTROL" == "N" || "$LOGIN_ITEM_CONTROL" == "n" ]]; then
            LOGIN_ITEM_CONTROL="allow"
            append_log "\n${RED}You indicated no. Students will be able to save login items.${NC}"
        else
            append_log "\n${GREEN}Invalid or no entry. Defaulting to allow. Students will be able to save login items.${NC}"
            LOGIN_ITEM_CONTROL="allow"
        fi
    else
        append_log "\n${GREEN}Timeout has expired. Defaulting to allow. Students will be able to save login items.${NC}"
        LOGIN_ITEM_CONTROL="allow"
    fi

    echo "-------------------------------"

    (( option_number += 1 ))
    # Override time constraints. 'No' means student control enabled on nights/weekends.
    if read -s -k 1 -t 600 "TIME_CONSTRAINT_OVERRIDE?[${option_number}/${total_options}] Override the time constraints and enforce btenforce options 24x7? (Y/[${ORANGE}N${NC}]): "; then
        if [[ "$TIME_CONSTRAINT_OVERRIDE" == "Y" || "$TIME_CONSTRAINT_OVERRIDE" == "y" ]]; then
            TIME_CONSTRAINT_OVERRIDE="true"
            append_log "\n${GREEN}You indicated yes. Time constraint override is enabled. 24x7 enforcement.${NC}"
        elif [[ "$TIME_CONSTRAINT_OVERRIDE" == "N" || "$TIME_CONSTRAINT_OVERRIDE" == "n" ]]; then
            TIME_CONSTRAINT_OVERRIDE="false"
            append_log "\n${GREEN}You indicated no. Time constraint override is disabled. Student control enabled on nights and weekends.${NC}"
        else
            append_log "\n${GREEN}Invalid or no entry. Defaulting to allow. Time constraint override is disabled.${NC}"
            TIME_CONSTRAINT_OVERRIDE="false"
        fi
    else
        append_log "\n${GREEN}Timeout has expired. Defaulting to allow. Time constraint override is disabled.${NC}"
        TIME_CONSTRAINT_OVERRIDE="false"
    fi

    echo "-------------------------------"

    # ((option_number++))
    # Organization's fully qualified domain name (FQDN).
    # Not used in this version, but will be in a future version.
    # fqdn_regex='^([a-zA-Z0-9-]{1,63}\.)+[a-zA-Z]{2,}$'
    # if read -t 600 "BTENFORCE_DOMAIN?[${option_number}/${total_options}] Enter your organization's fully qualified domain name ([${ORANGE}ENTER${NC}] to skip): "; then
    #     if [[ -z $BTENFORCE_DOMAIN ]]; then
    #         BTENFORCE_DOMAIN=""
    #         append_log "${YELLOW}Skipping FQDN entry.${NC}"
    #     elif [[ $BTENFORCE_DOMAIN =~ $fqdn_regex ]]; then
    #         if [[ "$BTENFORCE_DOMAIN" == *"yourdomain"* ]]; then
    #             append_log "${GREEN}Using default FQDN of ${BTENFORCE_DOMAIN}.${NC}"
    #         else
    #             append_log "${GREEN}Using FQDN of ${BTENFORCE_DOMAIN}.${NC}"
    #         fi
