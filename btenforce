# Add the date and time stamp to the log file.
append_log () {
    local message="$1"

    # Check if the log directory exists and create it if it does not.
    if [[ -z "$BTENFORCE_LOG_DIR" ]]; then
        BTENFORCE_LOG_DIR="/var/log/btenforce"
    fi

    if [[ ! -d "$BTENFORCE_LOG_DIR" ]]; then
        mkdir -p "$BTENFORCE_LOG_DIR"
        chmod 755 "$BTENFORCE_LOG_DIR"
    fi

    if [[ -z "$BTENFORCE_LOG_FILE" ]]; then
        BTENFORCE_LOG_FILE="${BTENFORCE_LOG_DIR}/btenforce-${TODAY}.log"
    fi
    
    # The sed pipeline removes ANSI escape sequences and deletes the first line if it is empty.
    local clean_text="$( echo -e "$message" | sed 's/\x1b\[[0-9;]*m//g' | sed '1{/^$/d;}' )"
    
    local date_stamp="$( date +"%Y-%m-%d %H:%M:%S" )"
    local file_log_msg="[BTENFORCE]${date_stamp} -- ${clean_text}"
    local syslog_msg="version ${VERSION} -- ${clean_text}"

    # If stdout is a terminal (interactive session), keep the colors.
    if [[ -t 1 ]]; then
        # Echo the message with the ANSI color codes to the terminal.
        echo -e "$message"
    fi

    # Append clean message to the persistent log file
    echo "$file_log_msg" >> "$BTENFORCE_LOG_FILE"
    
    # Log to syslog without echoing to stderr again
    logger -i -t btenforce "$syslog_msg"
}

# Function to display debug information.
debug_info() {
    local files_to_check log_size current_bt_status current_interval

    loggedInUser=$( echo "show State:/Users/ConsoleUser" | scutil | awk '/Name :/ && ! /loginwindow/ { print $3 }' )
    uid=$( id -u "$loggedInUser" 2>/dev/null ) || true
    
    # Count the actual number of entries in the config file.
    actual_config_entries=$( grep -E '^[A-Za-z_][A-Za-z0-9_]*=.*' "$BTENFORCE_CONFIG" | wc -l | xargs )

    # Get current interval
    current_interval=$( plutil -extract "StartInterval" raw "$PLIST" 2>/dev/null )

    files_to_check=("$NIGHTWKN_FLAG" "$INACTIVE_FLAG" "$OVERRIDE_FLAG" "$NO_LOGIN_FLAG" "$PLIST" "$BTENFORCE_CONFIG" "$BTENFORCE_LOG_FILE" "/usr/local/bin/blueutil")

    # Output header for the section.
    append_log "====================[ Debug mode has been enabled ] ===================="

    for file in "${files_to_check[@]}"; do
        if [[ -f "$file" ]]; then
            append_log "${file} exists"
        else
            append_log "${file} does not exist"
        fi
    done

    # Size of the current log file.
    log_size=$( du -sh "$BTENFORCE_LOG_FILE" | awk '{ print $1 }' )

    # Number of files in the log directory.
	log_count=$( find "$BTENFORCE_LOG_DIR" -maxdepth 1 -type f | wc -l | xargs )

    # Required to run as root.
    export BLUEUTIL_ALLOW_ROOT=1
    
    current_bt_status=$( launchctl asuser "$uid" sudo -u "$loggedInUser" "$BLUEUTIL" -p 2>/dev/null )
    if [[ "${current_bt_status}" == "0" ]]; then
        current_bt_status="enabled"
    elif [[ "${current_bt_status}" == "1" ]]; then
        current_bt_status="disabled"
    else
        current_bt_status="unknown"
    fi

    append_log "Current Bluetooth status: ${current_bt_status}"
    append_log "Log file count:           ${log_count}"
    append_log "Log file size:            ${log_size}"
    append_log "btenforce Version:        ${VERSION}"
    append_log "Script Path:              ${SCRIPT_PATH}"
    append_log "Active User:              ${loggedInUser}"
    append_log "User ID:                  ${uid}"
    append_log "Today:                    ${TODAY}"
    append_log "Current interval:         ${current_interval} (from plist)"
    append_log "Configured interval:      ${BTENFORCE_INTERVAL} (from config file)"
    append_log "Config file entries:      ${actual_config_entries} (Expected: ${EXPECTED_CONFIG_ENTRIES})"
    append_log "BTENFORCE_ACTIVE:         ${BTENFORCE_ACTIVE}"
    append_log "BTENFORCE_START_TIME:     ${BTENFORCE_START_TIME}"
    append_log "BTENFORCE_STOP_TIME:      ${BTENFORCE_STOP_TIME}"
    append_log "BLUETOOTH_CONTROL:        ${BLUETOOTH_CONTROL}"
    append_log "SAFARI_CONTROL:           ${SAFARI_CONTROL}"
    append_log "SAFARI_CONTROL_METHOD:    ${SAFARI_CONTROL_METHOD}"
    append_log "BTENFORCE_DOMAIN:         ${BTENFORCE_DOMAIN}"
    append_log "LOGIN_ITEM_CONTROL:       ${LOGIN_ITEM_CONTROL}"
    append_log "TIME_CONSTRAINT_OVERRIDE: ${TIME_CONSTRAINT_OVERRIDE}"
    append_log "LOG_RETENTION:            ${LOG_RETENTION}"
    append_log "BTENFORCE_LOG_DIR:        ${BTENFORCE_LOG_DIR}"
    
    dlc=$( launchctl print system/com.itech.btenforce | grep 'last exit code' | xargs | awk '{ print $5 }' )
    dri=$( launchctl print system/com.itech.btenforce | grep 'interval' | xargs | awk '{ print $4 }' )
    drc=$( launchctl print system/com.itech.btenforce | grep 'runs' | xargs | awk '{ print $3 }' )
    ral=$( launchctl print system/com.itech.btenforce | grep 'properties' | tail -1 | xargs | awk '{ print $3 }' )

    if [[ "$dlc" == "" ]] || [[ -z "$dlc" ]]; then
        dlc="   ?"
    fi

    if [[ "$dri" == "" ]] || [[ -z "$dri" ]]; then
        dri="   ?"
    fi

    if [[ "$drc" == "" ]] || [[ -z "$dri" ]]; then
        drc="   ?"
    fi

    if [[ "$ral" == "runatload" ]]; then
        ral="True"
    else
        ral="   ?"
    fi

    dlc="${(r:4:)dlc}"
    dri="${(r:4:)dri}"
    drc="${(r:4:)drc}"
    ral="${(r:4:)ral}"

    append_log " ╔═════════════════════════════╗"
    append_log " ║     LAUNCH DAEMON INFO      ║"
    append_log " ║ Last Exit Code:       ${dlc}  ║"
    append_log " ║ Current Run Interval: ${dri}  ║" 
    append_log " ║ Daemon Run Count:     ${drc}  ║"
    append_log " ║ Run at Load:          ${ral}  ║" 
    append_log " ╚═════════════════════════════╝" 
    append_log "========================================================================="

}

# Function to validate that a time value is formatted correctly. 24-hour clock.
check_time_integer() {
    local time="$1"
    local time_regex='^([0-9]|0[0-9]|1[0-9]|2[0-3]):[0-5][0-9]$'

    if [[ ! "$time" =~ $time_regex ]]; then
        return 1
	fi

	# Split the string on the colon character into an array.
	local time_array=(${(s/:/)time})

	local hour="${time_array[1]}"
	local minute="${time_array[2]}"

	# Using 10# forces base-10 evaluation, avoiding octal errors with 08 or 09.
	if (( 10#$hour >= 0 && 10#$hour <= 23 )) && (( 10#$minute >= 0 && 10#$minute <= 59 )); then
		return 0
	fi
    return 1
}

# Function to add a leading zero to the first digit in the time if missing.
add_leading_zero() {
    local time="$1"
	local time_array=(${(s/:/)time})
	local hour="${time_array[1]}"
	local minute="${time_array[2]}"

	# Strip any existing leading zeros to avoid double padding
	hour="${hour#"${hour%%[!0]*}"}"
	minute="${minute#"${minute%%[!0]*}"}"
	
	# If they were entirely zeros (e.g. "00"), they become empty. Default to 0.
	hour="${hour:-0}"
	minute="${minute:-0}"

	printf "%02d:%02d\n" "$hour" "$minute"
}

# Configuration function. Called with -configure argument.
configure_btenforce() {
    failed_items=0

    clear
    echo -e "${NC}${brand_tag}"

    local total_options=11
    local option_number=0

    TERM=xterm-256color

    # Check to ensure that the config file path is valid.
    config_dir=$( dirname "$BTENFORCE_CONFIG" )
    if [[ ! -d "$config_dir" ]]; then
        mkdir -p "$config_dir"
        if [[ $? -ne 0 ]]; then
            append_log "\n${RED}Could not create configuration directory: ${config_dir}. Exiting.${NC}"
            exit 1
        else
            append_log "\n${GREEN}Configuration directory confirmed: ${config_dir}${NC}"
        fi
    fi

    # Username of the user currently logged on and their ID.
    local config_user=$( echo "show State:/Users/ConsoleUser" | scutil | awk '/Name :/ && ! /loginwindow/ { print $3 }' )


    if (( EUID != 0 )); then
        append_log "\n${RED}Error: This script must be run with sudo or as root.${NC}\n" >&2
        exit 1
    fi

    echo -e "\nPlease note that this utility changes the configuration of btenforce on"
    echo -e "${SB}this computer only${EB}. To change the config on multiple computers, use the"
    echo -e "post-install script: ${ORANGE}btenforce-postinstall.sh${NC} using an MDM.\n"

    echo -e "Press ENTER for the default value shown in square brackets or make a selection:\n"

    local timeout=600
    local timeout_msg="\n${YELLOW}Timeout has expired. The default option has been set.${NC}"

    # Main option to enable or disable all checks.
    (( option_number += 1 ))		
    if read -s -k 1 -t "$timeout" "BTENFORCE_ACTIVE?[${option_number}/${total_options}] Enable btenforce? ([${ORANGE}Y${NC}]/N): "; then
        if [[ "$BTENFORCE_ACTIVE" == "N" || "$BTENFORCE_ACTIVE" == "n" ]]; then
            BTENFORCE_ACTIVE="false"
            append_log "\n${YELLOW}You indicated no. btenforce is now disabled. btenforce will exit without enforcing any options.${NC}"
        else
            append_log "\n${GREEN}You indicated yes. btenforce is now enabled.${NC}"
            BTENFORCE_ACTIVE="true"
        fi
    else
        append_log "$timeout_msg"
        BTENFORCE_ACTIVE="true"
    fi

    echo "-------------------------------"


    # Option to modify the time between checks.
    (( option_number += 1 ))		
    local interval_default=5
    local interval_regex='^([1-9]|[1-9][0-9]{1,2}|[1-2][0-9]{3}|3[0-5][0-9]{2}|3600)$'
    if read -t "$timeout" "BTENFORCE_INTERVAL?[${option_number}/${total_options}] Enter the number of seconds between 1 and 3600 to wait between checks [${ORANGE}${interval_default}${NC}]: "; then
        if [[ -z "$BTENFORCE_INTERVAL" ]]; then
            BTENFORCE_INTERVAL="$interval_default"
            echo -e "\n${GREEN}Using default interval ${BTENFORCE_INTERVAL}.${NC}"
        else
            # Check against regex.
            if [[ "$BTENFORCE_INTERVAL" =~ "$interval_regex" ]]; then
                if [[ "$BTENFORCE_INTERVAL" -le 4 ]]; then
                    echo -e "\n${YELLOW}An interval of less than 5 seconds may be too short! 5 is optimal.${NC}"
                else
                    echo -e "\n${GREEN}Setting interval to ${BTENFORCE_INTERVAL}."
                fi
            else
                echo -e "\n${RED}Invalid value entered: ${BTENFORCE_INTERVAL} - Defaulting to ${interval_default} seconds.${NC}"
                BTENFORCE_INTERVAL="$interval_default"
            fi
        fi
    else
        echo -e "$timeout_msg"
        BTENFORCE_INTERVAL="${interval_default}"
    fi

    # Modify the plist and restart the daemon if the Interval was changed from its default.
    if [[ "$BTENFORCE_INTERVAL" != "$interval_default" ]]; then
        set_btenforce_interval
    fi

    echo "-------------------------------"

    # Safari option. 'enforce' or 'allow'
    (( option_number += 1 ))
    if read -s -k 1 -t "$timeout" "SAFARI_CONTROL?[${option_number}/${total_options}] Enforce Safari restrictions? (force students to use Chrome, for example) (Y/[${ORANGE}N${NC}]): "; then
        if [[ "$SAFARI_CONTROL" == "Y" || "$SAFARI_CONTROL" == "y" ]]; then
            SAFARI_CONTROL="enforce"
            append_log "\n${GREEN}You indicated yes. Safari restrictions are now enabled. Students will not be able to use Safari.${NC}"
        else
            append_log "\n${YELLOW}You indicated no. Safari restrictions are now disabled. Students will be able to use Safari.${NC}"
            SAFARI_CONTROL="allow"
        fi
    else
        append_log "$timeout_msg"
        SAFARI_CONTROL="allow"
    fi

    echo "-------------------------------"

    # Bluetooth option. 'enforce' or 'allow'
    (( option_number += 1 ))
    if read -s -k 1 -t "$timeout" "BLUETOOTH_CONTROL?[${option_number}/${total_options}] Enforce Bluetooth restrictions? ('yes' = students will not be able to turn off Bluetooth) ([${ORANGE}Y${NC}]/N): "; then
        if [[ "$BLUETOOTH_CONTROL" == "N" || "$BLUETOOTH_CONTROL" == "n" ]]; then
            BLUETOOTH_CONTROL="allow"
            append_log "\n${YELLOW}You indicated no. Bluetooth enforcement is now disabled. Students will be able to turn off Bluetooth.${NC}"
        else
            append_log "\n${GREEN}You indicated yes. Bluetooth enforcement is now enabled. Students will not be able to turn off Bluetooth.${NC}"
            BLUETOOTH_CONTROL="enforce"
        fi
    else
        append_log "$timeout_msg"
        BLUETOOTH_CONTROL="enforce"
    fi

    echo "-------------------------------"

    (( option_number += 1 ))
    # Login item controls. 'enforce' or 'allow'
    if read -s -k 1 -t "$timeout" "LOGIN_ITEM_CONTROL?[${option_number}/${total_options}] Enforce login item controls? ('yes = restrict students from adding or removing login items) (Y/[${ORANGE}N${NC}]): "; then
        if [[ "$LOGIN_ITEM_CONTROL" == "Y" || "$LOGIN_ITEM_CONTROL" == "y" ]]; then
            LOGIN_ITEM_CONTROL="enforce"
            append_log "\n${GREEN}You indicated yes. Students will not be able to save login items.${NC}"
        else
            append_log "\n${YELLOW}Students will be able to save login items.${NC}"
            LOGIN_ITEM_CONTROL="allow"
        fi
    else
        append_log "$timeout_msg"
        LOGIN_ITEM_CONTROL="allow"
    fi

    echo "-------------------------------"

    (( option_number += 1 ))
    # Override time constraints. 'No' means student control enabled on nights/weekends.
    if read -s -k 1 -t "$timeout" "TIME_CONSTRAINT_OVERRIDE?[${option_number}/${total_options}] Override the time constraints and enforce btenforce options 24x7? (Y/[${ORANGE}N${NC}]): "; then
        if [[ "$TIME_CONSTRAINT_OVERRIDE" == "Y" || "$TIME_CONSTRAINT_OVERRIDE" == "y" ]]; then
            TIME_CONSTRAINT_OVERRIDE="true"
            append_log "\n${GREEN}You indicated yes. Time constraint override is enabled. 24x7 enforcement in effect.${NC}"
        else
            append_log "\n${GREEN}Time constraint override is disabled. Enforcement only active during school hours.${NC}"
            TIME_CONSTRAINT_OVERRIDE="false"
        fi
    else
        append_log "$timeout_msg"
        TIME_CONSTRAINT_OVERRIDE="false"
    fi

    echo "-------------------------------"

    (( option_number += 1 ))
    # Safari blocking option. 'osascript', 'pgrep'
    if read -s -k 1 -t "$timeout" "SAFARI_CONTROL_METHOD?[${option_number}/${total_options}] Enter Safari blocking method: (Osascript/[${ORANGE}P${NC}]grep): "; then
        if [[ "$SAFARI_CONTROL_METHOD" == "O" || "$SAFARI_CONTROL_METHOD" == "o" ]]; then
            SAFARI_CONTROL_METHOD="osascript"
            append_log "\n${GREEN}You indicated Osascript. Safari blocking method is osascript.${NC}"
            append_log "${ORANGE}osascript may require a configuration profile to set the permissions."
            append_log "Use pgrep method instead if students are prompted for permissions.${NC}"
        else
            SAFARI_CONTROL_METHOD="pgrep"
            append_log "\n${GREEN}Safari control method is set to pgrep.${NC}"
        fi
    else
        append_log "$timeout_msg"
        SAFARI_CONTROL_METHOD="pgrep"
    fi

    echo "-------------------------------"

    (( option_number += 1 ))
    # School start time in 24-hour clock. HH:mm
    if read -t "$timeout" "BTENFORCE_START_TIME?[${option_number}/${total_options}] Enter school start time (5 characters as in 07:00 or press ENTER for [${ORANGE}07:00${NC}]): "; then
        if [[ -z "$BTENFORCE_START_TIME" ]]; then
            append_log "\n${GREEN}Using default school start time of 07:00.${NC}"
            BTENFORCE_START_TIME="07:00"
        else
            
            # Double check that the time is a valid time.
            BTENFORCE_START_TIME=$( add_leading_zero "$BTENFORCE_START_TIME" )
            if check_time_integer "$BTENFORCE_START_TIME"; then
                append_log "\n${GREEN}School start time is set to ${BTENFORCE_START_TIME}.${NC}"
            else
                append_log "\n${RED}Invalid value entered: ${BTENFORCE_START_TIME} - Defaulting to 07:00.${NC}"
                BTENFORCE_START_TIME="07:00"
            fi
        fi
    else
        append_log "$timeout_msg"
        BTENFORCE_START_TIME="07:00"
    fi

    echo "-------------------------------"  

    (( option_number += 1 ))
    # School stop time in 24-hour clock. HH:mm
    if read -t "$timeout" "BTENFORCE_STOP_TIME?[${option_number}/${total_options}] Enter school stop time (5 characters as in 15:00 or press ENTER for [${ORANGE}15:00${NC}]): "; then
        if [[ -z "$BTENFORCE_STOP_TIME" ]]; then
            append_log "\n${GREEN}Using default school stop time of 15:00.${NC}"
            BTENFORCE_STOP_TIME="15:00"
        else
            # Double check that the time is a valid time.
            BTENFORCE_STOP_TIME=$( add_leading_zero "$BTENFORCE_STOP_TIME" )
            if check_time_integer "$BTENFORCE_STOP_TIME"; then
                append_log "\n${GREEN}School stop time is set to ${BTENFORCE_STOP_TIME}.${NC}"
            else
                append_log "\n${RED}Invalid value entered: ${BTENFORCE_STOP_TIME} - Defaulting to 15:00.${NC}"
                BTENFORCE_STOP_TIME="15:00"
            fi
        fi
    else
        append_log "$timeout_msg"
        BTENFORCE_STOP_TIME="15:00"
    fi

    echo "-------------------------------"

    (( option_number += 1 ))
    # Set the retention period for log files. Default is 180 days.

    log_retention_regex='^([1-9][0-9]{0,2}|10[0-8][0-9]|109[0-5])$'
    if read -t "$timeout" "LOG_RETENTION?[${option_number}/${total_options}] Enter log retention period in days from 7-1095 (Press enter for [${ORANGE}180${NC}]): "; then
        if [[ -z "$LOG_RETENTION" ]]; then
            append_log "\n${GREEN}Using default log retention of 180 days.${NC}"
            LOG_RETENTION="180"
        elif [[ "$LOG_RETENTION" =~ $log_retention_regex ]]; then
            append_log "\n${GREEN}Log retention is set to ${LOG_RETENTION} days.${NC}"
        else
            append_log "\n${RED}Invalid value entered: ${LOG_RETENTION}. Min: 7, Max: 1095, Default: 180.${NC}"
            LOG_RETENTION="180"
        fi
    else
        append_log "$timeout_msg"
        LOG_RETENTION="180"
    fi

    echo "-------------------------------"

    (( option_number += 1 ))
    # Log file path. Use a new variable so that the log currently running isn't affected.
    local new_log_path=""
    if read -t "$timeout" "new_log_path?[${option_number}/${total_options}] Enter log file directory (press enter for [${ORANGE}${BTENFORCE_LOG_DIR}${NC}]): "; then
        if [[ -z "$new_log_path" ]]; then
            append_log "\n${GREEN}Using ${BTENFORCE_LOG_DIR}${NC}"
            new_log_path="$BTENFORCE_LOG_DIR"
        else
            append_log "\n${GREEN}Log file path is set to ${new_log_path}.${NC}"
        fi
    else
        append_log "$timeout_msg"
        new_log_path="$BTENFORCE_LOG_DIR"
    fi

    echo "-------------------------------"

    # Warn if all options are set to allow.
    if [[ "$BTENFORCE_ACTIVE" == "true" ]] && [[ "$BLUETOOTH_CONTROL" == "allow" ]] && [[ "$SAFARI_CONTROL" == "allow" ]] && [[ "$LOGIN_ITEM_CONTROL" == "allow" ]]; then
        append_log "${YELLOW}⚠️ WARNING: btenforce was enabled, but none of the controls are active."
        append_log "btenforce will run but not take any action. Please re-run setup to enable options.${NC}"
        sleep 4
    fi

    append_log "\n${GREEN}Writing configuration file: ${BTENFORCE_CONFIG}\n${NC}"
    cat << EOF > "$BTENFORCE_CONFIG"
${brand_tag}

# Version: ${VERSION}
# Configured on: $( date +"%Y-%m-%d %H:%M:%S" ) | via btenforce -configure option
# Configured by: ${config_user}
# Configuration script path: ${SCRIPT_PATH}

# Enable/disable the daemon (true/false).
BTENFORCE_ACTIVE="$BTENFORCE_ACTIVE"

# Interval between checks in seconds (1-3600).
BTENFORCE_INTERVAL="$BTENFORCE_INTERVAL"

# Fully qualified domain name.
BTENFORCE_DOMAIN="$BTENFORCE_DOMAIN"

# Safari blocking option. 'enforce', 'allow'.
SAFARI_CONTROL="$SAFARI_CONTROL"

# Safari blocking method. 'osascript', 'pgrep'.
SAFARI_CONTROL_METHOD="$SAFARI_CONTROL_METHOD"

# Bluetooth blocking option. 'enforce', 'allow'.
BLUETOOTH_CONTROL="$BLUETOOTH_CONTROL"

# Login item control. 'enforce', 'allow'.
LOGIN_ITEM_CONTROL="$LOGIN_ITEM_CONTROL"

# School start time in 24-hour clock. Format: HH:MM.
BTENFORCE_START_TIME="$BTENFORCE_START_TIME"

# School stop time in 24-hour clock. Format: HH:MM.
BTENFORCE_STOP_TIME="$BTENFORCE_STOP_TIME"

# Log file path (directory only - a new file is created each day with the date in the filename).
BTENFORCE_LOG_DIR="$new_log_path"

# Time constraint override.
TIME_CONSTRAINT_OVERRIDE="$TIME_CONSTRAINT_OVERRIDE"

# Log retention in days.
LOG_RETENTION="$LOG_RETENTION"
EOF

    chmod 644 "$BTENFORCE_CONFIG"
    chown root:wheel "$BTENFORCE_CONFIG"
    
    echo -e "${NC}"
    cat "$BTENFORCE_CONFIG"
    echo -e "${NC}"

    # Prompt whether to start from the beginning or exit.
    if read -s -k 1 -t 120 "FINAL_RESTART?Would you like to restart the configuration? (Y/[${ORANGE}N${NC}]): "; then
        if [[ "$FINAL_RESTART" == "Y" || "$FINAL_RESTART" == "y" ]]; then
            append_log "\n${YELLOW}Restarting the configuration process...${NC}"
            sleep 2
            configure_btenforce
        else
            append_log "\n${GREEN}Configuration complete. To make additional changes, re-run ${ORANGE}sudo btenforce -configure${NC}."
            exit 0
        fi
    else
        append_log "\n${GREEN}Configuration complete. To make additional changes, re-run ${ORANGE}sudo btenforce -configure${NC}."
        exit 1
    fi
}

