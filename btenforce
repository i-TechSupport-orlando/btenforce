# Exit if running as a regular user. Prevents reconfiguring by standard users.
(( EUID != 0 )) && { append_log "Must be run as root"; exit 112; }

# Source the configuration file.
if [[ -f "$BTENFORCE_CONFIG" ]]; then
    source "$BTENFORCE_CONFIG"

    # Clean up legacy BTENFORCE_LOG_FILE and ensure only a single BTENFORCE_LOG_DIR exists.
    if grep -q "^BTENFORCE_LOG_FILE=" "$BTENFORCE_CONFIG" || [[ $(grep -c "^BTENFORCE_LOG_DIR=" "$BTENFORCE_CONFIG") -gt 1 ]]; then
        local extracted_dir="/var/log/btenforce"
        
        # Try to extract the directory path from existing entries
        if grep -q "^BTENFORCE_LOG_DIR=" "$BTENFORCE_CONFIG"; then
            extracted_dir=$(grep "^BTENFORCE_LOG_DIR=" "$BTENFORCE_CONFIG" | head -n 1 | cut -d'"' -f2)
        elif grep -q "^BTENFORCE_LOG_FILE=" "$BTENFORCE_CONFIG"; then
            local legacy_val
            legacy_val=$(grep "^BTENFORCE_LOG_FILE=" "$BTENFORCE_CONFIG" | head -n 1 | cut -d'"' -f2)
            if [[ -n "$legacy_val" ]]; then
                if [[ -d "$legacy_val" ]]; then
                    extracted_dir="$legacy_val"
                else
                    extracted_dir=$(dirname "$legacy_val")
                fi
            fi
        fi

        # Remove all instances of BTENFORCE_LOG_FILE and BTENFORCE_LOG_DIR
        grep -v -E "^(BTENFORCE_LOG_FILE|BTENFORCE_LOG_DIR)=" "$BTENFORCE_CONFIG" > "${BTENFORCE_CONFIG}.tmp" && mv "${BTENFORCE_CONFIG}.tmp" "$BTENFORCE_CONFIG"

        # Write a single clean BTENFORCE_LOG_DIR variable
        echo "BTENFORCE_LOG_DIR=\"${extracted_dir}\"" >> "$BTENFORCE_CONFIG"
        
        chmod 644 "$BTENFORCE_CONFIG"
        chown root:wheel "$BTENFORCE_CONFIG"
        
        # Re-source config to load the corrected values
        source "$BTENFORCE_CONFIG"
    fi

    # Ensure BTENFORCE_LOG_DIR has a default value if not set in config
    BTENFORCE_LOG_DIR="${BTENFORCE_LOG_DIR:-/var/log/btenforce}"
    
    # Dynamically construct the log file path
    BTENFORCE_LOG_FILE="${BTENFORCE_LOG_DIR}/btenforce-${TODAY}.log"
else
    append_log "Unable to find ${BTENFORCE_CONFIG}"
    exit 1
fi

# Get logged in user.
loggedInUser=$( echo "show State:/Users/ConsoleUser" | scutil | awk '/Name :/ && ! /loginwindow/ { print $3 }' )

# Set trap for graceful exit
