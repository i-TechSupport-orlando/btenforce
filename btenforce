        new_log_path="$BTENFORCE_LOG_FILE"
    fi

    echo "-------------------------------"


    # Check whether the log file path is valid. If not, use the default path.
    if [[ -n "$new_log_path" ]]; then
        new_log_dir="$( dirname "$new_log_path" )"
        if [[ ! -d "$new_log_dir" ]]; then
            mkdir -p "$new_log_dir"
            if [[ $? -ne 0 ]]; then
                append_log "\n${RED}Could not create log directory: ${new_log_dir}. Using ${BTENFORCE_LOG_FILE}${NC}"
                new_log_path="$BTENFORCE_LOG_FILE"
            else
                append_log "\n${GREEN}Log directory confirmed: ${new_log_dir}${NC}"
            fi
        fi
    fi


    append_log "\n${GREEN}Writing configuration file: ${BTENFORCE_CONFIG}\n${NC}"
    cat << EOF > "$BTENFORCE_CONFIG"

