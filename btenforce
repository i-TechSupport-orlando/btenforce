# Function to run a command as the logged in user.
runAsUser() {
    # Recheck for logged in user before executing osascript in the event the user logs out between the initial check and this function call.
    loggedInUser=$( echo "show State:/Users/ConsoleUser" | scutil | awk '/Name :/ && ! /loginwindow/ { print $3 }' )

    if [[ -z "${loggedInUser}" ]] && [[ "${loggedInUser}" != "loginwindow" ]]; then
	    # Exit if no user is logged in. btenforce is user-facing.
	    append_log "No user logged in. Exiting."
	    exit 0
    fi

    uid=$( id -u "${loggedInUser}" 2>/dev/null ) || true

    # Execute the command sent to the function as the logged in user.
    launchctl asuser "$uid" sudo -u "$loggedInUser" "$@" || true
}

# Function to remove log files older than the retention period.
prune_logs () {
    local retention="${1:-$LOG_RETENTION}"
    local log_dir="${2:-$BTENFORCE_LOG_DIR}"

    # Default to 180 days if missing or empty.
    if [[ -z "$retention" ]] || [[ "$retention" == "" ]]; then
        retention="180"
        if ! fix_missing_vars; then
            append_log "Failed to fix missing vars."
            return 1
        fi
    fi

    # Remove log files older than the retention period.
    find "${log_dir}" \
        -name "*.log" \
        -type f \
        -mtime +"${retention}" \
        -delete
    
    if [[ $? -ne 0 ]]; then
        return 1
    fi

    return 0
}

set_btenforce_interval () {
    if [[ -z "$BTENFORCE_INTERVAL" ]]; then
        BTENFORCE_INTERVAL="5"
    fi

    # Get current interval
    current_interval=$( plutil -extract "StartInterval" raw "$PLIST" 2>/dev/null )
    
    if [[ "$current_interval" == "$BTENFORCE_INTERVAL" ]]; then
        return 0
    fi

    # Replace the interval.
    plutil -replace StartInterval -integer "$BTENFORCE_INTERVAL" "$PLIST"
    
    # Fix permissions.
    chown root:wheel "$PLIST"
    chmod 644 "$PLIST"

    # Validate the plist file.
    plutil -lint "$PLIST"
    if [[ $? -ne 0 ]]; then
        append_log "${RED}Error: Could not validate the plist file.${NC}"
        return 1
    fi

    append_log "${GREEN}Set interval to ${BTENFORCE_INTERVAL} seconds.${NC}"

    return 0
}

# Download and install the LaunchDaemon if it doesn't exist.
download_daemon () {
    local daemon_url temp_file sha256 sha256_local
    daemon_url="https://raw.githubusercontent.com/i-TechSupport-orlando/btenforce/refs/heads/main/com.itech.btenforce.plist"
    temp_file="/tmp/com.itech.btenforce.plist.new"

    # Get expected sha256 checksum.
    sha256=$( curl -fsSL "$daemon_url" | shasum -a 256 | awk '{ print $1 }' )

    if [[ -z "$sha256" ]] || [[ "${#sha256}" -ne 64 ]]; then
        append_log "Error: Could not get sha256 checksum of daemon. Output: ${sha256}"
        return 1
    fi

    local max_attempts=3
    local attempt=1

    while [[ "$attempt" -le "$max_attempts" ]]; do
        if curl -fsSL "$daemon_url" -o "$temp_file"; then
            sha256_local=$( shasum -a 256 "$temp_file" | awk '{ print $1 }' )

            if [[ "$sha256_local" != "$sha256" ]]; then
                append_log "Error: SHA256 checksum of downloaded daemon does not match expected checksum."
                rm -f "$temp_file"
            else
                if ! mv "$temp_file" "$PLIST"; then
                    append_log "Error: Could not move daemon to ${PLIST}."
                    rm -f "$temp_file"
                    return 1
                fi

                if chown root:wheel "$PLIST"; then
                    append_log "Ownership of daemon changed to root:wheel."
                else
                    append_log "Failed to change ownership of daemon to root:wheel."
                    return 1
                fi

                if chmod 644 "$PLIST"; then
                    append_log "Permissions of daemon set to 644."
                else
                    append_log "Failed to set permissions of daemon to 644."
                    return 1
                fi

                return 0
            fi
        else
            append_log "Error: Could not download daemon from GitHub on attempt ${attempt}. Retrying..."
        fi

        sleep 2
        (( attempt += 1 ))
    done

    append_log "Error: Could not download daemon from GitHub after ${max_attempts} attempts."
    return 1
}

# Function to install the LaunchDaemon.
install_daemon () {
    
    if ! download_daemon; then
        append_log "Failed to download daemon."
        return 1
    fi

    append_log "Starting new LaunchDaemon..."

    launchctl bootstrap system "$PLIST"

    sleep 2

    daemon_status=$( launchctl list | grep "com.itech.btenforce" || true )

    if [[ -n "$daemon_status" ]]; then
        append_log "LaunchDaemon installed and loaded."
        return 0
    else
        append_log "LaunchDaemon failed to start. Reattempting to bootstrap..."
        launchctl bootstrap system "$PLIST"
        sleep 3
        daemon_status=$( launchctl list | grep "com.itech.btenforce" || true )
        if [[ -n "$daemon_status" ]]; then
            append_log "LaunchDaemon installed and loaded."
            return 0
        else
            append_log "LaunchDaemon failed to start."
            return 1
        fi
    fi
}

download_blueutil () {
    
