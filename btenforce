    #         BTENFORCE_DOMAIN=""
    #     fi
    # else
    #     append_log "${GREEN}Skipping FQDN entry.${NC}"
    #     BTENFORCE_DOMAIN=""
    # fi

    # echo "-------------------------------"

    (( option_number += 1 ))
