    # School stop time in 24-hour clock. HH:mm
    if read -t 600 "BTENFORCE_STOP_TIME?[${option_number}/${total_options}] Enter school stop time (5 characters as in 15:00 or press ENTER for [${ORANGE}15:00${NC}]): "; then
        if [[ -z "$BTENFORCE_STOP_TIME" ]]; then
