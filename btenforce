# Check whether Bluetooth is on or off.
check_bluetooth () {

    local blue_util_src="/usr/local/share/blueutil"
    
    # Double check that blueutil is executable.
    if [[ ! -x "$BLUEUTIL" ]]; then
        if [[ -f "$blue_util_src" ]]; then
            cp "$blue_util_src" "$BLUEUTIL"
            if [[ ! -f "$BLUEUTIL" ]]; then
                append_log "Could not find ${BLUEUTIL}."
                if ! download_blueutil; then
                    append_log "Failed to download blueutil. Exiting without action."
                    return 1
                else
                    append_log "Downloaded blueutil from GitHub."
                fi
            fi
        else
            append_log "Error: Could not find Bluetooth utility source file at ${blue_util_src}. Attempting to download blueutil from GitHub."
            if ! download_blueutil; then
                append_log "Failed to download blueutil. Exiting without action."
                return 1
            fi
        fi
        chmod +x "$BLUEUTIL"
        append_log "Copied Bluetooth utility from ${blue_util_src} to ${BLUEUTIL}."
    fi

    loggedInUser=$( echo "show State:/Users/ConsoleUser" | scutil | awk '/Name :/ && ! /loginwindow/ { print $3 }' )
    uid=$( id -u "$loggedInUser" 2>/dev/null ) || true

    # Required to run as root.
    export BLUEUTIL_ALLOW_ROOT=1
    
    bstatus=$( launchctl asuser "$uid" sudo -u "$loggedInUser" "$BLUEUTIL" -p )
    
    # If Bluetooth is off, turn it back on.
    if [[ "$bstatus" -eq 0 ]]; then
        launchctl asuser "$uid" sudo -u "$loggedInUser" "$BLUEUTIL" --power 1 2>/dev/null || true
        append_log "Reactivated Bluetooth. User: ${loggedInUser}"
    fi
}

# Close Safari by killing the process if it's open.
check_safari () {
    
    if [[ "$SAFARI_CONTROL_METHOD" == "osascript" ]]; then
    
        safari_is_open=$( runAsUser osascript -e '
tell application "System Events"
set safariRunning to (name of processes) contains "Safari"
end tell

if safariRunning then
    tell application "Safari"
        if (count of windows) > 0 then
            return "true"
        end if
    end tell
end if

return "false"
' 2>/dev/null )
        if [[ "$safari_is_open" == "true" ]]; then
            killall Safari &> /dev/null
            append_log "Killed Safari for ${loggedInUser} via osascript."
            return 0
        fi
    elif [[ "$SAFARI_CONTROL_METHOD" == "pgrep" ]]; then
            safariProcs=$( ps aux | pgrep Safari )
            
        if pgrep -x "Safari" >/dev/null; then
            killall Safari &> /dev/null
            append_log "Killed Safari for ${loggedInUser} via pgrep"
            return 0
        fi
    else
        append_log "Invalid SAFARI_CONTROL_METHOD in ${BTENFORCE_CONFIG}."
        return 1
    fi
}

# Check whether the current date/time is during regular school hours.
during_school_hours () {
    if [[ "$BTENFORCE_DEBUG_MODE" == "true" || "$TIME_CONSTRAINT_OVERRIDE" == "true" ]]; then
        if [[ -f "$OVERRIDE_FLAG" ]]; then
            return 0
        else
            set_flag "$OVERRIDE_FLAG"
            append_log "School hours are not being considered due to debug mode or time constraint override set to true. Created override flag."
            return 0
        fi
    else
        if [[ -f "$OVERRIDE_FLAG" ]]; then
            rm -f "$OVERRIDE_FLAG"
            append_log "School hours are now being considered. Removed override flag."
        fi
    fi

    # Get current time
    current_hour=$(date +%H)
    current_minute=$(date +%M)
    day_of_week=$(date +%u)
    
    # Convert to integers
    current_total_minutes=$((10#$current_hour * 60 + 10#$current_minute))
    
    # Extract hours and minutes from HH:MM strings and calculate total minutes
    start_hour=${BTENFORCE_START_TIME%:*}
    start_minute=${BTENFORCE_START_TIME#*:}
    start_total_minutes=$((10#$start_hour * 60 + 10#$start_minute))

    end_hour=${BTENFORCE_STOP_TIME%:*}
    end_minute=${BTENFORCE_STOP_TIME#*:}
    end_total_minutes=$((10#$end_hour * 60 + 10#$end_minute))
    
    # Check if weekday (Mon–Fri) and time is between start and end
    if (( day_of_week >= 1 && day_of_week <= 5 )); then
        if (( current_total_minutes >= start_total_minutes && current_total_minutes < end_total_minutes )); then
            return 0
        fi
    fi
    
    return 1
}

# Check if any login items exist for the current user.
check_login_items () {
    login_item_count=$(runAsUser osascript -e '
    tell application "System Events"
    count login items
    end tell
    ' 2>/dev/null)
        
    if [[ "$login_item_count" =~ ^[0-9]+$ ]] && [[ "$login_item_count" -gt 0 ]]; then
        runAsUser osascript -e 'tell application "System Events" to delete login items' 2>/dev/null
        append_log "Removed ${login_item_count} login items for ${loggedInUser}"
    fi
}

finished() {
    if [[ "$EXIT_CODE" -ne 0 ]]; then
        append_log "Exit code ${EXIT_CODE}."
    fi
    
    exit "$EXIT_CODE"
}

trapint() {
    if [[ -t 1 ]]; then
        append_log "Control-C was pressed. Script terminated by ${loggedInUser}."
    else
        append_log "btenforce received a Control-C sequence or SIGKILL from an unknown source."
    fi

	exit "$EXIT_CODE"
}

set_flag () {
    local file="$1"

    if [[ -z "$file" ]]; then
        append_log "No file argument received in set_flag function."
        return 1
    fi

    if ! touch "$file"; then
        append_log "Could not create flag file: ${file}."
        return 1
    fi

    if ! chmod 644 "$file"; then
        append_log "Could not set permissions to 644: ${file}."
        return 1
    fi
    
    if ! chown root:wheel "$file"; then
        append_log "Could not set ownership to root:wheel: ${file}."
        return 1
    fi
    
    append_log "Created ${file}"
    return 0
}

